{
  "name": "jspsych-ado",
  "version": "0.2.0",
  "description": "In-browser adaptive design optimization (ADO) for jsPsych experiments — Stan/WASM, no server, no Python.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "jspsych",
    "adaptive-design-optimization",
    "ado",
    "stan",
    "webassembly",
    "bayesian",
    "psychophysics"
  ],
  "homepage": "https://github.com/kiante-fernandez/jspsych-ado#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kiante-fernandez/jspsych-ado.git"
  },
  "bugs": {
    "url": "https://github.com/kiante-fernandez/jspsych-ado/issues"
  },
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./models/*": "./src/models/*",
    "./tasks/*": "./src/tasks/*",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/model.js",
    "**/main.js"
  ],
  "files": [
    "src",
    "core/tinystan",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test tests/js/*.test.mjs",
    "test:smoke": "node tests/js/stan_recovery.smoke.mjs",
    "test:browser": "node tests/browser/dd_smoke.mjs && node tests/browser/line_length_discrimination_smoke.mjs && node tests/browser/magnitude_estimation_smoke.mjs && node tests/browser/byo_model_exponential_smoke.mjs && node tests/browser/byo_task_money_choice_smoke.mjs",
    "patch:wasm": "node scripts/patch-wasm-glue.mjs",
    "test:bundler": "node tests/bundler/run.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm test && npm run typecheck",
    "prepare": "husky"
  },
  "author": "The jspsych-ado contributors",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@jspsych/plugin-call-function": ">=1",
    "@jspsych/plugin-canvas-keyboard-response": ">=1",
    "@jspsych/plugin-canvas-slider-response": ">=1",
    "@jspsych/plugin-html-button-response": ">=1",
    "jspsych": ">=7"
  },
  "peerDependenciesMeta": {
    "@jspsych/plugin-html-button-response": {
      "optional": true
    },
    "@jspsych/plugin-call-function": {
      "optional": true
    },
    "@jspsych/plugin-canvas-keyboard-response": {
      "optional": true
    },
    "@jspsych/plugin-canvas-slider-response": {
      "optional": true
    }
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "puppeteer": "^24.15.0",
    "typescript": "^6.0.3"
  },
  "prettier": {
    "printWidth": 100
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,json,md,css}": "prettier --write"
  }
}
